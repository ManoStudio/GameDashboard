{
  "name": "game-dashboard-cloudflare",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:create": "wrangler d1 create game-dashboard-db",
    "r2:create": "wrangler r2 bucket create game-dashboard-builds",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply game-dashboard-db --local && wrangler d1 migrations apply game-dashboard-db --remote"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
